---
// ProjectCard — props: title, tags[], description, githubSlug
interface Props {
  title: string;
  tags: string[];
  description: string;
  githubSlug: string;
}
const { title, tags, description, githubSlug } = Astro.props;
const githubUrl = `https://github.com/mahsikit/${githubSlug}`;
---

<div class="project-card bg-slate-800 border border-slate-700 rounded-xl p-5 flex flex-col gap-4">

  <!-- Tech tags (top) -->
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="skill-pill">{tag}</span>
    ))}
  </div>

  <!-- Title + description -->
  <div class="flex-1">
    <h3 class="text-base font-semibold text-slate-100 mb-1.5">{title}</h3>
    <p class="text-sm text-slate-400 leading-relaxed">{description}</p>
  </div>

  <!-- GitHub link -->
  <a
    href={githubUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 text-xs font-mono text-sky-400 hover:text-sky-300 transition-colors self-start group"
  >
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.11.82-.26.82-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.757-1.333-1.757-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.468-2.382 1.236-3.222-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 3-.405c1.02.005 2.047.138 3 .405 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.235 1.912 1.235 3.222 0 4.61-2.807 5.625-5.48 5.92.43.372.823 1.102.823 2.222v3.293c0 .32.218.694.825.576C20.565 21.796 24 17.298 24 12c0-6.63-5.37-12-12-12z"/>
    </svg>
    GitHub
    <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
  </a>

</div>
