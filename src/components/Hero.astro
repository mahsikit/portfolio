---
// Hero — name, dual title, stat bar, CTA buttons, Available badge, dot-grid bg
---

<section
  id="hero"
  class="hero-bg relative flex items-center min-h-screen pt-14 overflow-hidden"
>
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24">

    <!-- Available badge -->
    <div class="inline-flex items-center gap-2 bg-slate-800 border border-slate-700 rounded-full px-3 py-1 mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      <span class="text-xs text-slate-300 font-mono">Available for opportunities</span>
    </div>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl font-bold text-slate-100 leading-tight mb-2">
      Jonathan Santoso
    </h1>
    <!-- Accent underline -->
    <div class="w-16 h-0.5 bg-sky-400 mb-5"></div>

    <!-- Dual title -->
    <p class="text-xl sm:text-2xl text-slate-400 font-medium mb-10">
      Analytics Engineer &nbsp;·&nbsp; Senior Data Analyst
    </p>

    <!-- Stat bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12 max-w-xl">
      {[
        { value: '2+',   label: 'years\nexperience' },
        { value: '8',    label: 'tools\nbuilt' },
        { value: '3.89', label: 'GPA' },
        { value: '1',    label: 'Springer\npaper' },
      ].map(({ value, label }) => (
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-4 text-center">
          <div class="text-3xl font-bold text-sky-400">{value}</div>
          <div class="text-xs text-slate-400 mt-1 whitespace-pre-line leading-tight">{label}</div>
        </div>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-wrap gap-3">
      <a
        href="#experience"
        class="inline-flex items-center gap-2 bg-sky-500 hover:bg-sky-400 text-slate-900 font-semibold text-sm px-5 py-2.5 rounded transition-colors"
      >
        View Experience
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center gap-2 border border-slate-600 hover:border-sky-400 text-slate-300 hover:text-sky-400 text-sm px-5 py-2.5 rounded transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download CV
      </a>
      <a
        href="https://github.com/mahsikit"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-slate-600 hover:border-sky-400 text-slate-300 hover:text-sky-400 text-sm px-5 py-2.5 rounded transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.11.82-.26.82-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.757-1.333-1.757-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.468-2.382 1.236-3.222-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 3-.405c1.02.005 2.047.138 3 .405 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.235 1.912 1.235 3.222 0 4.61-2.807 5.625-5.48 5.92.43.372.823 1.102.823 2.222v3.293c0 .32.218.694.825.576C20.565 21.796 24 17.298 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/jonathansantoso"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-slate-600 hover:border-sky-400 text-slate-300 hover:text-sky-400 text-sm px-5 py-2.5 rounded transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

  </div>
</section>
