---
const certs = [
  { logo: '/icons/powerbi.svg', logoBg: 'bg-white', name: 'Power BI Data Analyst Associate', issuer: 'Microsoft Certified' },
  { logo: '/icons/azure.svg',   logoBg: 'bg-white', name: 'Azure Data Fundamentals',          issuer: 'Microsoft Certified' },
  { logo: '/icons/tableau.svg', logoBg: 'bg-white', name: 'Certified Data Analyst',            issuer: 'Tableau' },
  { logo: '/icons/python.svg',  logoBg: '',          name: 'Python Essentials 1',               issuer: 'Cisco' },
  { logo: '/icons/google.svg',  logoBg: '',          name: 'Foundations: Data, Data, Everywhere', issuer: 'Google' },
];
---

<section id="certifications" class="py-24" style="background: rgba(12,26,45,0.4);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="fade-in mb-14">
      <span class="section-marker">// 04</span>
      <h2 class="text-2xl font-bold text-[#d8eaf5]">Certifications &amp; Publication</h2>
      <div class="w-8 h-[1.5px] mt-2" style="background: linear-gradient(to right, #00e5b4, transparent);"></div>
    </div>

    <!-- Cert cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-5">
      {certs.map(({ logo, logoBg, name, issuer }) => (
        <div class="fade-in bg-[#0c1a2d] border border-[#162d48] rounded-xl p-4 flex items-start gap-3
                    hover:border-[#00e5b4]/30 transition-colors duration-200">
          <div class={`shrink-0 w-10 h-10 rounded-lg flex items-center justify-center p-1.5 ${logoBg || 'bg-[#162d48]'}`}>
            <img src={logo} alt={issuer + ' logo'} class="w-full h-full object-contain" width="128" height="128" />
          </div>
          <div>
            <p class="text-sm font-medium text-[#d8eaf5] leading-snug">{name}</p>
            <p class="text-xs text-[#5a7a96] mt-0.5 font-mono">{issuer}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Publication card -->
    <div class="fade-in bg-[#0c1a2d] border border-[#162d48] rounded-xl p-5 flex items-start gap-4
                hover:border-[#00e5b4]/30 transition-colors duration-200"
         style="border-left: 2px solid rgba(0,229,180,0.4);">
      <div class="shrink-0 w-10 h-10 rounded-lg bg-[#162d48] flex items-center justify-center text-base select-none">
        📄
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-[#d8eaf5] leading-snug">
          Sentiment Analysis on Google Play Store User Reviews of Digital Bank Applications in Indonesia
        </p>
        <p class="text-xs text-[#5a7a96] mt-1 font-mono">Springer · March 2024</p>
      </div>
      <a href="https://doi.org/10.1007/978-3-031-54019-6_29"
         target="_blank" rel="noopener noreferrer"
         class="shrink-0 inline-flex items-center gap-1 text-xs font-mono text-[#00e5b4] hover:text-[#00c9a0] transition-colors self-start mt-0.5 group">
        Read
        <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
