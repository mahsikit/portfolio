---

<section id="projects" class="py-24" style="background: rgba(12,26,45,0.4);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="fade-in mb-14">
      <span class="section-marker">// 02</span>
      <h2 class="text-2xl font-bold text-[#d8eaf5]">Projects</h2>
      <div class="w-8 h-[1.5px] mt-2" style="background: linear-gradient(to right, #00e5b4, transparent);"></div>
    </div>

    <!-- Group 1 -->
    <div class="fade-in mb-5">
      <p class="text-[11px] font-mono text-[#00e5b4] uppercase tracking-[0.15em] opacity-60">Production Tools</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {productionProjects.map((p) => (
        <div class="fade-in h-full">
          <ProjectCard {...p} />
        </div>
      ))}
    </div>

    <!-- Group 2 -->
    <div class="fade-in mb-5">
      <p class="text-[11px] font-mono text-[#00e5b4] uppercase tracking-[0.15em] opacity-60">Data, Analytics &amp; Earlier Work</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {analyticsProjects.map((p) => (
        <div class="fade-in h-full">
          <ProjectCard {...p} />
        </div>
      ))}
    </div>

  </div>
</section>
